# Dockerfile.gateway – container image for the LLM Gateway service
FROM python:3.11-slim

# Install build tools (if needed by any dependencies)
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
       build-essential \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install this package (and its dependencies)
# Hatchling expects the README referenced in *pyproject.toml* to be present
# during metadata generation.  Without it `pip install -e .` fails inside the
# container build.  Include the README explicitly so the editable install
# succeeds even when we copy only the minimal build inputs.
# Copy full source into image first so the package can be installed normally.
COPY . .

# Install package in *non-editable* mode so runtime does not rely on source
# mounts.  This avoids import errors when the container is started without the
# volume or with a different working directory.
RUN pip install --no-cache-dir pip setuptools wheel \
    && pip install --no-cache-dir .

# Expose the Gateway port and launch uvicorn
EXPOSE 9000
ENTRYPOINT ["uvicorn", "edgar_ai.gateway.server:app", "--host", "0.0.0.0", "--port", "9000"]
